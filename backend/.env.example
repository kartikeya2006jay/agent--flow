# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# === Application ===
PROJECT_NAME=AgentFlow OS
VERSION=0.1.0
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# === Security (CHANGE THESE IN PRODUCTION!) ===
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Database ===
# For development (SQLite):
# DATABASE_URL=sqlite:///./agentflow.db
#
# For production (PostgreSQL):
DATABASE_URL=postgresql://user:password@localhost:5432/agentflow

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === CORS ===
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# === Business Logic ===
AUTO_APPROVAL_AMOUNT_THRESHOLD=1000.0

# === Logging ===
LOG_LEVEL=INFO

# === External APIs ===
# Add API keys for integrations here
OPENAI_API_KEY=your-openai-key-here
STRIPE_API_KEY=your-stripe-key-here
