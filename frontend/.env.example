# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# === API Configuration ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_TIMEOUT_MS=30000

# === Auth Configuration ===
NEXT_PUBLIC_AUTH_TOKEN_KEY=agentflow_token
NEXT_PUBLIC_AUTH_USER_KEY=agentflow_user

# === App Configuration ===
NEXT_PUBLIC_APP_NAME=AgentFlow OS
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_ENV=development

# === OpenAI/RAG Configuration (Server-Side Only) ===
# ⚠️ These are used ONLY in /api/rag/chat route, never exposed to browser
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3
MOCK_LLM=true

# === RAG Context Sources ===
RAG_KNOWLEDGE_BASE_URL=http://localhost:8000/api/v1/knowledge
RAG_VECTOR_STORE=chroma
RAG_EMBEDDING_MODEL=text-embedding-3-small

# === Features ===
NEXT_PUBLIC_WEBSOCKET_ENABLED=true
NEXT_PUBLIC_POLLING_INTERVAL_MS=30000
